# vSphere MCP Server Configuration
# Copia questo file come .env e configura i valori appropriati

# vCenter Configuration
VCENTER_HOST=vcenter.domain.local
VCENTER_USER=username@domain.local
VCENTER_PASSWORD=your_password_here

# SSL Configuration (True = disable SSL verification, False = enable SSL verification)
# In ambienti enterprise è comune disabilitare la verifica SSL
INSECURE=True
